# ── Groq ──────────────────────────────────────────────
GROQ_API_KEY=YOUR_API_KEY

# ── Wake Word ──────────────────────────────────────────
WAKEWORD_MODEL=hey jarvis        # openwakeword model name
MIC_INDEX=1                   # PyAudio device index (run list_mics.py to find yours)
WAKEWORD_THRESHOLD=0.5        # detection confidence threshold (0.0–1.0)
WAKEWORD_COOLDOWN=2           # seconds before re-triggering allowed

# ── Recording ─────────────────────────────────────────
RECORDING_SECONDS=3           # how long to record after wake word
SAMPLE_RATE=16000             # Hz — must match openwakeword

# ── LLM ───────────────────────────────────────────────
LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=256
SYSTEM_PROMPT=You are a helpful voice assistant. Keep replies short and conversational.

# ── STT ───────────────────────────────────────────────
STT_MODEL=whisper-large-v3-turbo   # faster + cheaper; switch to whisper-large-v3 for accuracy
STT_LANGUAGE=en

# ── TTS ───────────────────────────────────────────────
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=autumn              # options: tara, leah, leo, dan, mia, zac, jess, julia, autumn


# ── Robot Serial (ESP32) ───────────────────────────────
# Run: python list_ports.py to find your port
# Raspberry Pi USB-Serial: usually /dev/ttyUSB0 or /dev/ttyACM0
SERIAL_PORT=/dev/ttyACM0
SERIAL_BAUD=115200            # must match Arduino Serial.begin() value